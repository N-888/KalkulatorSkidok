# Игнорируем папку виртуального окружения Python
venv/

# Игнорируем кэш Python (автоматически создаваемые файлы)
__pycache__/

# Игнорируем кэш pytest
.pytest_cache/

# Игнорируем локальные файлы с реальными данными
*.json
*.txt

# Игнорируем файлы логов
logs.txt

# Игнорируем файлы истории
history.txt

# Игнорируем скрытые файлы Windows
Thumbs.db
Desktop.ini

# Игнорируем файлы IDE
.vscode/
.idea/
